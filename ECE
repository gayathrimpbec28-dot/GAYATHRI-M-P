 */

// Helper function to find GCD of two numbers
int gcd(int a, int b) {
    while (b > 0) {
        a %= b;
        int temp = a;
        a = b;
        b = temp;
    }
    return a;
}

// Helper function to find LCM of two numbers
int lcm(int a, int b) {
    if (a == 0 || b == 0) return 0;
    return abs(a * b) / gcd(a, b);
}

int getTotalX(int a_count, int* a, int b_count, int* b) {
    // 1. Find LCM of all elements in array a
    int res_lcm = a[0];
    for (int i = 1; i < a_count; i++) {
        res_lcm = lcm(res_lcm, a[i]);
    }

    // 2. Find GCD of all elements in array b
    int res_gcd = b[0];
    for (int i = 1; i < b_count; i++) {
        res_gcd = gcd(res_gcd, b[i]);
    }

    // 3. Count multiples of LCM that divide GCD
    int count = 0;
    for (int i = res_lcm, j = 2; i <= res_gcd; i = res_lcm * j, j++) {
        if (res_gcd % i == 0) {
            count++;
        }
    }

    return count;
}


