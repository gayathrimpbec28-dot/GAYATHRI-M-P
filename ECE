    long total_occupied = 0;
    
    for (int i = 0; i < k; i++) {
        int currentRow = track[i][0];
        long start = track[i][1];
        long end = track[i][2];

        // Merge all overlapping or contiguous tracks in the same row
        while (i + 1 < k && track[i + 1][0] == currentRow) {
            if (track[i + 1][1] <= end) {
                if (track[i + 1][2] > end) {
                    end = track[i + 1][2];
                }
                i++;
            } else {
                break;
            }
        }
        total_occupied += (end - start + 1);
    }

    // Use long for total area to prevent overflow
    return ((long)n * m) - total_occupied;
