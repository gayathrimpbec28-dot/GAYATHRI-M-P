void plusMinus(int arr_count, int* arr) {
    float positiveCount = 0;
    float negativeCount = 0;
    float zeroCount = 0;

    for (int i = 0; i < arr_count; i++) {
        if (arr[i] > 0) {
            positiveCount++;
        } else if (arr[i] < 0) {
            negativeCount++;
        } else {
            zeroCount++;
